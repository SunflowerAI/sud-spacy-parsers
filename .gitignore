# Python / build
.venv/
__pycache__/
*.egg-info/
build/
# spacy package staging dirs (e.g. build_lzh/)
build_*/
dist/
wheelbuild/
*.tgz
# downloaded deps + built wheels (models ship via GitHub Releases, not in-repo)
*.whl

# Raw SUD treebanks — re-download from https://grew.fr/download/ (see README).
# The relabelled derivatives + each LICENSE.txt are force-added (git add -f).
assets/SUD_English-EWT/
assets/SUD_English-GUM/
assets_zh/SUD_Chinese-GSDSimp/
assets_zh/SUD_Chinese-GSD/
assets_ko/SUD_Korean-GSD/
assets_id/SUD_Indonesian-GSD/

# Dual-script (simplified+traditional) build dirs. zh = GSD + GSDSimp combined;
# lzh = Kyoto + its OpenCC-t2s simplified copy. Regenerate with both_scripts_release.sh.
assets_zh/SUD_Chinese-GSDBoth/
assets_lzh/SUD_Classical_Chinese-Kyoto-Hans/
assets_lzh/SUD_Classical_Chinese-Kyoto-Both/

# GUM is CC BY-NC-SA (NonCommercial) — the English model/data ship EWT-only.
# Exclude every GUM-mixed English artifact; only assets/en_ewt-sud-*.relabeled*.conllu is published.
assets/en_sud-*.conllu
gold_udep.jsonl
metrics.json
metrics_relabeled.json
metrics_en_ext.json

# Trained parsers are distributed as release wheels, not committed.
training_*/

# pkuseg segmenter model — regenerate with scripts/train_pkuseg_zh.py.
models/

# Build artifacts / logs
corpus_*/
*.log
# scratch --review output; the hand-corrections live in sa_ufal_csl_overrides.tsv
sa_ufal_csl_review.tsv

# one-off / scratch driver scripts (not part of the reproducible pipeline)
scripts/finish_phase4.sh
scripts/overnight_arla_ext.sh
scripts/retrain_trimmed.sh
scripts/run_japanese.sh

# New-language raw SUD treebanks — re-download from https://grew.fr/download/ (see README).
assets_fa/SUD_Persian-PerDT/
assets_ar/SUD_Arabic-PADT/
assets_la/SUD_Latin-ITTB/
assets_la2/SUD_Latin-PROIEL/
assets_la/la_ittbproiel-sud-*.conllu
assets_sa/SUD_Sanskrit-Vedic/
assets_sa_ufal/SUD_Sanskrit-UFAL/
assets_lzh/SUD_Classical_Chinese-Kyoto/
assets_ja/SUD_Japanese-GSD/
assets_yue/SUD_Cantonese-HK/
